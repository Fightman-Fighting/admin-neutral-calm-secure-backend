# Same Supabase project as neutral-calm-secure (use service role only on the server)
PORT=4001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Next.js dev server (default 3001)
CORS_ORIGIN=http://localhost:3001

# Optional: shared secret header x-admin-key for automation (bypasses profile check)
ADMIN_API_KEY=

# Access to Bearer /admin/* routes requires profiles.role = 'admin' for that user id
